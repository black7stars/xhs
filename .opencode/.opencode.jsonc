{
  "$schema": "https://opencode.ai/config.json",
  // 主题配置
  "theme": "opencode",
  // 默认模型
  "model": "opencode/kimi-k2.5-free",
  // 自动更新
  "autoupdate": true,
  // 服务器配置
  "server": {
    "port": 4096,
    "hostname": "127.0.0.1",
    "cors": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  }
}
