# 小红书餐饮融合料理笔记生成器 - 环境配置示例
# 复制此文件为 .env 并填入实际值

# ===== Banana生图API配置 =====
BANANA_API_HOST=https://grsai.dakka.com.cn/v1/draw/nano-banana-pro
BANANA_MODEL=nano-banana-pro
BANANA_API_KEY=your_banana_api_key_here

# ===== SiliconFlow图片分析API配置 =====
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Pro/moonshotai/Kimi-K2.5

# ===== 路径配置 =====
PROJECT_ROOT=/Users/black7stars/workspace/xhs
MATERIAL_BASE_DIR=/Users/black7stars/workspace/xhs/素材库/图片素材库
AI_IMAGE_OUTPUT_DIR=/Users/black7stars/workspace/xhs/AI生图
NOTES_OUTPUT_DIR=/Users/black7stars/workspace/xhs/笔记

# ===== 生图默认参数 =====
DEFAULT_IMAGE_COUNT=4
DEFAULT_WIDTH=1242
DEFAULT_HEIGHT=1660
DEFAULT_STEPS=30
DEFAULT_CFG=7.5

# ===== 重试配置 =====
MAX_RETRIES=3
RETRY_DELAY=2

# ===== 小红书平台参数 =====
XIAOHONGSHU_IMAGE_RATIO="3:4"
XIAOHONGSHU_IMAGE_WIDTH=1242
XIAOHONGSHU_IMAGE_HEIGHT=1660
